<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Sistema de Biblioteca</title>
</head>

<body>
    <!-- ENCABEZADO -->
    <center id="top">
        <table width="100%" bgcolor="#DDD6FF" cellpadding="20" cellspacing="0" border="0">
            <tr>
                <td align="center">
                    <font size="7" face="Arial Black, Arial"><b>Biblioteca Cronopio </b></font>
                    <p>
                        <font size="4"><b> Sistema de gestión de libros y préstamos - Encuentra tu próxima lectura aquí
                            </b></font>
                    </p>
                    <br>
                    <font size="4">
                        <a href="#buscador">
                            <font color="#000000"><b>🔍 Buscador</b></font>
                        </a> &nbsp;&nbsp;&nbsp;
                        <a href="#categorias">
                            <font color="#000000"><b>🏷️ Categorías</b></font>
                        </a> &nbsp;&nbsp;&nbsp;
                        <a href="#libros">
                            <font color="#000000"><b>📗 Libros</b></font>
                        </a> &nbsp;&nbsp;&nbsp;
                        <a href="#prestamos">
                            <font color="#000000"><b>📋 Préstamos</b></font>
                        </a> &nbsp;&nbsp;&nbsp;
                        <a href="#formulario">
                            <font color="#000000"><b>📝 Registrar</b></font>
                        </a> &nbsp;&nbsp;&nbsp;
                        <a href="#pie">
                            <font color="#000000"><b>ℹ️ Contacto</b></font>
                        </a>
                    </font>
                </td>
            </tr>
        </table>
    </center>

    <hr size="3" color="#5dade2" width="100%">
<!-- buscador -->
<center id="buscador">
    <table width="90%" bgcolor="#ffffff" cellpadding="20" cellspacing="0" border="2" bordercolor="#85c1e9">
        <tr>
            <td align="center" bgcolor="#aed6f1">
                <font size="6" color="#000000"><b>🔍 Buscador</b></font>

                <p>
                <!-- formulario  -->
                <form action="#" method="get">
                    <font size="5">

                        <!-- etiqueta del campo de búsqueda -->
                        <label for="buscar"><b>Buscar libro:</b></label><br>

                        <!-- campo donde el usuario escribe -->
                        <input type="text" id="buscar" name="buscar"
                            placeholder="Título, autor o editorial" size="40">

                        <!-- botón para realizar la búsqueda -->
                        <input type="submit" value="Buscar">

                    </font>
                </form>
                </p>

                <!-- mensaje de ayuda para el usuario -->
                <p>
                    <font color="#000000" size="2">
                        <b>Tip: Escribe el nombre del libro, autor o editorial para buscar</b>
                    </font>
                </p>
            </td>
        </tr>
    </table>
</center>

    <hr size="3" color="#e74c3c" width="100%">

    <!-- CATEGORÍAS -->
    <center id="categorias">
        <table width="90%" bgcolor="#ffffff" cellpadding="20" cellspacing="0" border="2" bordercolor="#85c1e9">
            <tr>
                <td align="center" bgcolor="#d5f4e6">
                    <font size="6" color="#000000"><b>Categorías</b></font>
                    <p>
                        <font size="4">
                            <a href="#libros">
                                <font color="#000000"><b>Novela</b></font>
                            </a> &nbsp;&nbsp;
                            <a href="#libros">
                                <font color="#000000"><b>Ciencia Ficción</b></font>
                            </a> &nbsp;&nbsp;
                            <a href="#libros">
                                <font color="#000000"><b>Historia</b></font>
                            </a> &nbsp;&nbsp;
                            <a href="#libros">
                                <font color="#000000"><b>Infantil</b></font>
                            </a> &nbsp;&nbsp;
                            <a href="#libros">
                                <font color="#000000"><b>Ciencia</b></font>
                            </a>
                        </font>
                    </p>
                    <p>
                        <font size="3"><b>Explora nuestras categorías</b>
                        </font>
                    </p>
                </td>
            </tr>
        </table>
    </center>

    <hr size="3" color="#27ae60" width="100%">

    <!-- LISTADO DE LIBROS -->
    <center id="libros">
        <table width="90%" bgcolor="#ffffff" cellpadding="20" cellspacing="0" border="2" bordercolor="#85c1e9">
            <tr>
                <td align="center">
                    <font size="6" color="#000000"><b>Listado de Libros</b></font>
                    <p>
                        <font size="3" color="#000000"><b>LIBROS DESTACADOS DEL MES </b></font>
                    </p>
                    <table align="center" border="3" cellpadding="15" cellspacing="20" width="90%" bgcolor="#f8f9fa">
                        <tr>
                            <!-- Libro 1 -->
                            <td align="center" bgcolor="#85c1e9" width="33%" valign="top">
                                <p>
                                    <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQ3PCsP09lXVs0GNdcvovY0WFm5FIou-4tlY21-U5xbNg&s=10"
                                        alt="Cien años de soledad" border="3" width="120" height="180">
                                </p>
                                <font size="5" color="#000000"><b>Cien años de soledad</b></font>
                                <br><br>
                                <font size="3" color="#000000">
                                    <b>Autor:</b> Gabriel García Márquez<br>
                                    <b>Año:</b>
                                    <font color="#e74c3c">1967</font><br>
                                    <b>Editorial:</b> Sudamericana<br>
                                    <b>Género:</b>
                                    <font color="#8e44ad">Realismo mágico</font>
                                </font>
                                <hr size="1" color="#85c1e9">
                                <font size="2" color="#000000"><b> Literatura latinoamericana</b></font>
                            </td>

                            <!-- Libro 2 -->
                            <td align="center" bgcolor="#e74c3c" width="33%" valign="top">
                                <p>
                                
                                <p>
                                    <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcShTn66xMlKLoP2Q-1H5ClHCjrmFgEZRa3AuUNd-uY_og&s" alt="1984"
                                        border="3" width="120" height="180">
                                </p>
                                <font size="5" color="#000000"><b>1984</b></font>
                                <br><br>
                                <font size="3" color="#000000">
                                    <b>Autor:</b> George Orwell<br>
                                    <b>Año:</b>
                                    <font color="#ffffff">1949</font><br>
                                    <b>Editorial:</b> Secker & Warburg<br>
                                    <b>Género:</b>
                                    <font color="#8e44ad">Distopía</font>
                                </font>
                                <hr size="1" color="#e74c3c">
                                <font size="2" color="#ffffff"><b>Literatura distópica</b>
                                </font>
                            </td>

                            <!-- Libro 3 -->
                            <td align="center" bgcolor="#27ae60" width="33%" valign="top">
                                <p>
                                    <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcR9Kr3luHV-Fowxejjkn7aAh7EtOMPZ2-dFMNMBtUWhTQ&s=10"
                                        alt="El Principito" border="3" width="120" height="180">
                                </p>
                                <font size="5" color="#000000"><b>El Principito</b></font>
                                <br><br>
                                <font size="3" color="#000000">
                                    <b>Autor:</b> Antoine de Saint-Exupéry<br>
                                    <b>Año:</b>
                                    <font color="#e74c3c">1943</font><br>
                                    <b>Editorial:</b> Reynal & Hitchcock<br>
                                    <b>Género:</b>
                                    <font color="#8e44ad">Literatura infantil</font>
                                </font>
                                <hr size="1" color="#27ae60">
                                <font size="2" color="#000000"><b>Una historia para todas las edades</b>
                                </font>
                            </td>
                        </tr>
                    </table>
                </td>
            </tr>
        </table>
    </center>

    <hr size="3" color="#9b59b6" width="100%">

    <!-- TABLA DE PRÉSTAMOS -->
    <center id="prestamos">
        <table width="90%" bgcolor="#ffffff" cellpadding="20" cellspacing="0" border="2" bordercolor="#85c1e9">
            <tr>
                <td align="center">
                    <font size="6" color="#000000"><b>📋 Historial de Préstamos Activos</b></font>
                    <p>
                    <table border="1" cellpadding="10" cellspacing="0" width="100%">
                        <tr bgcolor="#85c1e9">
                            <th>
                                <font face="Arial">Usuario</font>
                            </th>
                            <th>
                                <font face="Arial">Libro Prestado</font>
                            </th>
                            <th>
                                <font face="Arial">Fecha de Salida</font>
                            </th>
                            <th>
                                <font face="Arial">Estado</font>
                            </th>
                        </tr>
                        <tr>
                            <td>
                                <font face="Arial">Carlos Pérez</font>
                            </td>
                            <td>
                                <font face="Arial">Cien años de soledad</font>
                            </td>
                            <td>
                                <font face="Arial">10/07/2026</font>
                            </td>
                            <td bgcolor="#f9e79f" align="center"><b>
                                    <font face="Arial" color="#b7950b">En curso</font>
                                </b></td>
                        </tr>
                        <tr>
                            <td>
                                <font face="Arial">María López</font>
                            </td>
                            <td>
                                <font face="Arial">1984</font>
                            </td>
                            <td>
                                <font face="Arial">14/07/2026</font>
                            </td>
                            <td bgcolor="#f9e79f" align="center"><b>
                                    <font face="Arial" color="#b7950b">En curso</font>
                                </b></td>
                        </tr>
                    </table>
                    </p>
                </td>
            </tr>
        </table>
    </center>

    <hr size="3" color="#f39c12" width="100%">

    <!-- FORMULARIO DE PRÉSTAMO -->
    <center id="formulario">
        <table width="90%" bgcolor="#ffffff" cellpadding="20" cellspacing="0" border="2" bordercolor="#85c1e9">
            <tr>
                <td align="center" bgcolor="#fdebd0">
                    <font size="6" color="#000000"><b>📝 Registrar Nuevo Préstamo</b></font>
                    <p>
                    <form action="#" method="post">  <!-- no envía los datos a ningún servidor. -->
                        <table cellpadding="5" cellspacing="0" border="0">
                            <tr>
                                <td align="right">
                                    <font face="Arial"><b>Nombre del Estudiante:</b></font>
                                </td>
                                <td><input type="text" name="estudiante" required size="30"></td>
                            </tr>
                            <tr>
                                <td align="right">
                                    <font face="Arial"><b>Seleccionar Libro:</b></font>
                                </td>
                                <td>
                                    <select name="libro_seleccionado">
                                        <option value="1">Cien años de soledad</option>
                                        <option value="2">1984</option>
                                        <option value="3">El Principito</option>
                                    </select>
                                </td>                   
<center id="formulario">
</center>

<hr size="3" color="#5dade2" width="100%">

<!-- PIE DE PÁGINA -->
<center id="pie">
<table width="100%" bgcolor="#85c1e9" cellpadding="15" cellspacing="0" border="0">
    <tr>
        <td align="center">
            <font face="Arial" size="3">
                <b>Biblioteca</b><br><br>
                Dirección: Ciudad de Guatemala<br>
                Correo: biblioteca@umg.com<br>
                Teléfono: 1234-5678<br><br>

                <a href="#top">
                    <font ><b>⬆ Volver al inicio</b></font>
                </a>
            </font>
        </td>
    </tr>
</table>
</center>
</body>
</html>
                        
